{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@tresamigos/types": ["../../packages/types/dist/index.d.ts"],
      "@tresamigos/utils": ["../../packages/utils/dist/index.d.ts"]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noEmit": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src"]
}
