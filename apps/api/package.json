{
  "name": "@tresamigos/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch --path tsconfig.build.json",
    "build": "pnpm --filter @tresamigos/types build && pnpm --filter @tresamigos/utils build && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.12",
    "@nestjs/platform-express": "^11.0.12",
    "@prisma/client": "^6.5.0",
    "@tresamigos/types": "workspace:*",
    "@tresamigos/utils": "workspace:*",
    "ioredis": "^5.6.0",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "nodemailer": "^6.10.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.4",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
